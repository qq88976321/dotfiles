# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

[[ -f ~/.p10k.mise.zsh ]] && source ~/.p10k.mise.zsh

ZSH_THEME="powerlevel10k/powerlevel10k"

# oh-my-zsh is managed by chezmoi externals, so disable its self-update.
zstyle ':omz:update' mode disabled

# Skip url-quote-magic and bracketed-paste-magic; they slow down pastes.
DISABLE_MAGIC_FUNCTIONS="true"

# Do not let oh-my-zsh overwrite the terminal/tmux window title.
DISABLE_AUTO_TITLE="true"

# Timestamp format for `history`.
HIST_STAMPS="yyyy-mm-dd"

# Add wisely, as too many plugins slow down shell startup.
plugins=(
  command-not-found
  cp
  docker
  docker-compose
  extract
  git
  git-auto-fetch
  helm
  kubectl
  kubetail
  tmux
  zsh-syntax-highlighting
  zsh-autosuggestions
)

source "$ZSH"/oh-my-zsh.sh

# Keep the completion dump compiled. compinit loads the .zwc only when it is
# newer than the dump; a stale .zwc silently falls back to parsing the text
# dump on every startup (~400ms). Recompile in the background when needed.
{
  if [[ -s "$ZSH_COMPDUMP" && ( ! -s "${ZSH_COMPDUMP}.zwc" || "$ZSH_COMPDUMP" -nt "${ZSH_COMPDUMP}.zwc" ) ]]; then
    command rm -f "${ZSH_COMPDUMP}.zwc"
    zcompile "$ZSH_COMPDUMP"
  fi
} &!

###############################################################
# User configuration
###############################################################

alias ll='ls -alF'
alias make='make -j8'
# Use kitty's ssh kitten only when attached directly to kitty (not through
# tmux/screen or a plain terminal, and not on a host without the kitten binary
# such as a jump host); otherwise fall back to native ssh.
ssh() {
  if [[ "$TERM" == "xterm-kitty" ]] && (( $+commands[kitten] )); then
    kitten ssh "$@"
  else
    command ssh "$@"
  fi
}

# docker
alias lzd='lazydocker'

# kubectl
alias kx='kubectl ctx'
alias kt='kubetail'
alias kar='kubectl-argo-rollouts'

# chezmoi
alias c='chezmoi'

# tig
alias t='tig'

# avoid to clear history
alias clear='printf "\e[H\e[2J"'

# change the directory of current shell to chezmoi's source directory
ccd() {
    cd "$(chezmoi source-path)" || exit
}

# Set the WORDCHARS variable after Oh My Zsh is sourced.
# I want hyphen and underscore to also be a part of a word.
# ref: https://github.com/ohmyzsh/ohmyzsh/wiki/FAQ#kill-word-or-backward-kill-word-do--dont-delete-a-symbol-wordchars
WORDCHARS='_-'

# Set history related options
export HISTSIZE=10000000
export SAVEHIST=10000000
setopt BANG_HIST                 # Treat the '!' character specially during expansion.
setopt EXTENDED_HISTORY          # Write the history file in the ":start:elapsed;command" format.
setopt INC_APPEND_HISTORY        # Write to the history file immediately, not when the shell exits.
setopt SHARE_HISTORY             # Share history between all sessions.
setopt HIST_EXPIRE_DUPS_FIRST    # Expire duplicate entries first when trimming history.
setopt HIST_IGNORE_DUPS          # Don't record an entry that was just recorded again.
setopt HIST_IGNORE_ALL_DUPS      # Delete old recorded entry if new entry is a duplicate.
setopt HIST_FIND_NO_DUPS         # Do not display a line previously found.
setopt HIST_IGNORE_SPACE         # Don't record an entry starting with a space.
setopt HIST_SAVE_NO_DUPS         # Don't write duplicate entries in the history file.
setopt HIST_REDUCE_BLANKS        # Remove superfluous blanks before recording entry.
setopt HIST_VERIFY               # Don't execute immediately upon history expansion.

# git-auto-fetch
GIT_AUTO_FETCH_INTERVAL=7200 # in seconds

###############################################################
# Powerlevel10k
###############################################################
# To customize prompt, run `p10k configure` or edit $HOME/.p10k.zsh.
if [[ -f "$HOME/.p10k.zsh" ]]; then
  source "$HOME/.p10k.zsh"
else
  echo "p10k: init script not found. Please check: https://github.com/romkatv/powerlevel10k#installation"
fi

###############################################################
# tool init hooks
###############################################################
# Order matters: mise activate must run first because it puts mise-managed
# tools (fzf, atuin, glab, fd, rg, ...) onto PATH for the checks below.
# Missing tools stay silent here; install hints fire lazily via the
# command-not-found handler defined later.
(( $+commands[mise] ))         && eval "$(mise activate zsh)"
(( $+commands[fzf] ))          && source <(fzf --zsh)   # key bindings + fuzzy completion
(( $+commands[zoxide] ))       && eval "$(zoxide init zsh)"
(( $+commands[pay-respects] )) && eval "$(pay-respects zsh --alias fuck)"

if (( $+commands[atuin] )); then
  # --disable-up-arrow does not work, so unbind everything via ATUIN_NOBIND
  # and rebind only ctrl-r to the atuin search widget.
  export ATUIN_NOBIND="true"
  eval "$(atuin init zsh)"
  bindkey '^r' _atuin_search_widget
fi

###############################################################
# completion caching
###############################################################
# Cache generated completions in $ZSH_CACHE_DIR/completions (already in
# fpath) instead of generating them synchronously on every startup.
#
# Usage: _cache_completion <name> <generator-cmd...>
#   <name> is the completion name (file becomes _<name>); the first word of
#   the generator command is the binary that must exist.
#
# Skips entirely when the generator binary is absent, so calls for tools not
# installed on this machine are free. On the first run the file does not exist
# yet and compinit has already scanned fpath, so bridge the completion manually
# (same pattern as the oh-my-zsh docker plugin). Regeneration only runs when the
# binary is newer than the cached file (a version bump) or the cache is empty,
# which keeps startup cheap even with many registered tools.
_cache_completion() {
  local name="$1"; shift
  (( $+commands[$1] )) || return
  local comp="$ZSH_CACHE_DIR/completions/_$name"
  if [[ ! -f "$comp" ]]; then
    typeset -g -A _comps
    autoload -Uz "_$name"
    _comps[$name]="_$name"
  fi
  if [[ ! -s "$comp" || "$commands[$1]" -nt "$comp" ]]; then
    "$@" >| "$comp" &|
  fi
}

###############################################################
# cached completions (registrations)
###############################################################
# Completions cached in $ZSH_CACHE_DIR/completions and refreshed in the
# background. Missing-tool hints are handled by command-not-found, so no
# per-tool fallback echo here.
_cache_completion uv      uv generate-shell-completion zsh
_cache_completion chezmoi chezmoi completion zsh
_cache_completion atuin   atuin gen-completions --shell zsh

# cobra-style: <tool> completion zsh
_cache_completion helmfile              helmfile completion zsh
_cache_completion k9s                   k9s completion zsh
_cache_completion argocd                argocd completion zsh
_cache_completion kubectl-argo-rollouts kubectl-argo-rollouts completion zsh
_cache_completion codex                 codex completion zsh
_cache_completion opencode              opencode completion zsh
_cache_completion golangci-lint         golangci-lint completion zsh
_cache_completion npm                   npm completion zsh

# gh / glab use a -s flag
_cache_completion gh   gh completion -s zsh
_cache_completion glab glab completion -s zsh

# clap / tool-specific flag forms
_cache_completion yq     yq shell-completion zsh
_cache_completion rustup rustup completions zsh
_cache_completion cargo  rustup completions zsh cargo
_cache_completion ruff   ruff generate-shell-completion zsh
_cache_completion ty     ty generate-shell-completion zsh
_cache_completion just   just --completions zsh
_cache_completion fd     fd --gen-completions zsh
_cache_completion rg     rg --generate complete-zsh

# kubectl family aliases. `kubecolor completion zsh` emits kubectl's own
# completion (#compdef kubectl, function _kubectl), so saving it as _kubecolor
# breaks the autoload guard; reuse the working _kubectl instead. The omz
# kubectl plugin aliases k=kubectl but never registers its completion.
if (( $+_comps[kubectl] )); then
  (( $+commands[kubecolor] )) && compdef kubecolor=kubectl
  compdef k=kubectl
fi

###############################################################
# command-not-found: lazy install hints, then distro suggester
###############################################################
# The omz command-not-found plugin (loaded above) defines
# command_not_found_handler to query the distro package db. Preserve it under
# a new name, then wrap it: print a known install hint for expected tools and
# delegate everything else to the distro suggester.
(( $+functions[command_not_found_handler] )) && \
  functions[_omz_cnf_handler]=$functions[command_not_found_handler]

typeset -gA _install_hints=(
  mise         'https://mise.jdx.dev/getting-started.html'
  fzf          'https://github.com/junegunn/fzf#installation'
  zoxide       'https://github.com/ajeetdsouza/zoxide#installation'
  atuin        'https://github.com/atuinsh/atuin'
  pay-respects 'https://github.com/iffse/pay-respects'
  chezmoi      'https://www.chezmoi.io/install'
  uv           'https://github.com/astral-sh/uv#installation'
)

command_not_found_handler() {
  local cmd="$1"
  if [[ -n "${_install_hints[$cmd]}" ]]; then
    print -u2 "$cmd: not installed. Install: ${_install_hints[$cmd]}"
    return 127
  fi
  if (( $+functions[_omz_cnf_handler] )); then
    _omz_cnf_handler "$@"
    return $?
  fi
  print -u2 "zsh: command not found: $cmd"
  return 127
}

###############################################################
# local settings
###############################################################
# Machine-specific interactive settings go in ~/.zshrc.local (mirrors the
# ~/.zshenv.local hook) instead of editing the chezmoi-managed ~/.zshrc.
local_zshrc_file="$HOME/.zshrc.local"
if [[ -f "$local_zshrc_file" ]]; then
  source "$local_zshrc_file"
fi
