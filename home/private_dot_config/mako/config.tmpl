{{- if .is_desktop_env -}}
font=MesloLGS NF 10
anchor=top-right
width=400
height=150
margin=20
padding=8
border-size=3
border-radius=0
border-color=#aaaaaa
background-color=#282a2e
text-color=#c5c8c6
default-timeout=5000
ignore-timeout=0
max-visible=5
sort=-time
icons=0
markup=1
actions=1
history=1

[urgency=low]
border-color=#707880

[urgency=normal]
border-color=#aaaaaa

[urgency=high]
border-color=#a54242
default-timeout=0

[mode=do-not-disturb]
invisible=1
{{- end }}
