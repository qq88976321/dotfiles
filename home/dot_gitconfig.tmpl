# This is Git's per-user configuration file.
[user]
	name = {{ .name }}
	email = {{ .email }}
	signingkey = ~/.ssh/id_ed25519.pub
[core]
	filemode = true
	editor = vim
	excludesfile = ~/.gitignore
[alias]
	st = status
	ci = commit -s
	ca = commit --amend -s
	co = checkout
	br = branch
	df = diff
	pick = cherry-pick
	fp = format-patch
	la = log --graph --decorate --pretty=oneline --abbrev-commit --all
	ll = log --graph --decorate --pretty=oneline --abbrev-commit
	lf = log --stat --decorate --format=fuller abbrev-commit
	lg = log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold cyan)%aD%C(reset) %C(bold green)(%ar)%C(reset)%C(bold yellow)%d%C(reset)%n''          %C(white)%s%C(reset) %C(dim white)- %an%C(reset)' --all
	d = difftool
	wt = worktree
[color]
	ui = auto
	diff = auto
	status = auto
	branch = auto
	log = auto
[push]
	default = simple
	; create the upstream branch on first push without --set-upstream
	autoSetupRemote = true
[pull]
	rebase = true
[branch]
	; sort `git branch` by most recent activity
	sort = -committerdate
[column]
	ui = auto
[difftool]
	prompt = false
	# Be able to abort all diffs with `:cq` or `:cquit`
	trustExitCode = true
[diff]
	tool = vimdiff
	algorithm = histogram
	; highlight moved code differently from added/removed code
	colorMoved = default
[diff "sopsdiffer"]
	textconv = sops -d
[sequence]
	editor = interactive-rebase-tool
[merge]
	ff = no
	; show the common ancestor in conflict markers
	conflictstyle = zdiff3
[rebase]
	autosquash = true
	; move stacked branches along when rebasing their base
	updateRefs = true
[fetch]
	prune = true
[pager]
	branch = false
{{- if .private_git_repo }}
[url "git@{{ .private_git_repo }}:"]
	insteadOf = https://{{ .private_git_repo }}/
{{- end }}
[commit]
	gpgsign = true
	verbose = true
[rerere]
	enabled = true
	autoupdate = true
[gpg]
	format = ssh
[gpg "ssh"]
	allowedSignersFile = ~/.ssh/allowed_signers
